{
  "info": {
    "name": "SkillPath AI Request Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Alpha\",\n  \"email\": \"student@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"otp\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/verify-otp",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "verify-otp"]
            }
          }
        }
      ]
    },
    {
      "name": "Learning Paths",
      "item": [
        {
          "name": "Generate Learning Path via AI",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Full Stack Engineer\",\n  \"targetSkills\": [\"React Router\", \"Redux Toolkit\", \"Express MVC\"],\n  \"currentSkills\": [\"HTML\", \"CSS\"],\n  \"level\": \"Beginner\",\n  \"commitmentHours\": 12\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:5000/api/paths/generate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "paths", "generate"]
            }
          }
        }
      ]
    }
  ]
}
