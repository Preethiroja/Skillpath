{
  "openapi": "3.0.0",
  "info": {
    "title": "SkillPath AI Service API Documentation",
    "description": "REST API definitions for user profiles, AI learning path generations, real-time chats, and notifications controls.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["name", "email", "password"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "OTP verification initiated" }
        }
      }
    },
    "/auth/verify-otp": {
      "post": {
        "summary": "Verify OTP and complete activation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "otp": { "type": "string" }
                },
                "required": ["email", "otp"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successfully verified" }
        }
      }
    },
    "/paths/generate": {
      "post": {
        "summary": "Request AI roadmap recommendations",
        "security": [
          { "BearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "targetSkills": { "type": "array", "items": { "type": "string" } },
                  "level": { "type": "string" }
                },
                "required": ["title", "targetSkills"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Personalized path generated successfully" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
